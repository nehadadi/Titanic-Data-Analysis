        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Read the dataset\n",
        "df = pd.read_csv(\"Titanic-Dataset (1).csv\")\n",
        "\n",
        "# Select Age and Fare of first two passengers\n",
        "p1 = df.loc[0, [\"Age\", \"Fare\"]]\n",
        "p2 = df.loc[1, [\"Age\", \"Fare\"]]\n",
        "\n",
        "# Fill missing values (if any)\n",
        "p1 = p1.fillna(df[[\"Age\", \"Fare\"]].mean())\n",
        "p2 = p2.fillna(df[[\"Age\", \"Fare\"]].mean())\n",
        "\n",
        "# Calculate Euclidean Distance\n",
        "distance = np.sqrt(((p1 - p2) ** 2).sum())\n",
        "\n",
        "# Calculate Similarity\n",
        "similarity = 1 / (1 + distance)\n",
        "\n",
        "# Calculate Dissimilarity\n",
        "dissimilarity = distance / (1 + distance)\n",
        "\n",
        "# Display Results\n",
        "print(\"Passenger 1\")\n",
        "print(p1)\n",
        "\n",
        "print(\"\\nPassenger 2\")\n",
        "print(p2)\n",
        "\n",
        "print(\"\\nEuclidean Distance :\", round(distance, 2))\n",
        "print(\"Similarity         :\", round(similarity, 4))\n",
        "print(\"Dissimilarity      :\", round(dissimilarity, 4))\n",
        "\n",
        "# ---------- Graph ----------\n",
        "plt.figure(figsize=(7,6))\n",
        "\n",
        "# Plot the two passengers\n",
        "plt.scatter(p1[\"Age\"], p1[\"Fare\"], s=150, label=\"Passenger 1\")\n",
        "plt.scatter(p2[\"Age\"], p2[\"Fare\"], s=150, label=\"Passenger 2\")\n",
        "\n",
        "# Draw line showing Euclidean distance\n",
        "plt.plot([p1[\"Age\"], p2[\"Age\"]],\n",
        "         [p1[\"Fare\"], p2[\"Fare\"]])\n",
        "\n",
        "# Labels\n",
        "plt.text(p1[\"Age\"], p1[\"Fare\"], \" P1\")\n",
        "plt.text(p2[\"Age\"], p2[\"Fare\"], \" P2\")\n",
        "\n",
        "# Display similarity on graph\n",
        "plt.title(f\"Similarity = {similarity:.4f}\\nDissimilarity = {dissimilarity:.4f}\")\n",
        "\n",
        "plt.xlabel(\"Age\")\n",
        "plt.ylabel(\"Fare\")\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "\n",
        "plt.show()"
      ],
