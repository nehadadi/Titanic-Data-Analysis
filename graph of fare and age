      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "df = pd.read_csv(\"Titanic-Dataset (1).csv\")\n",
        "\n",
        "data = df[[\"Age\", \"Fare\"]].dropna()\n",
        "\n",
        "plt.figure(figsize=(8,6))\n",
        "plt.scatter(data[\"Age\"], data[\"Fare\"], label=\"All Passengers\")\n",
        "\n",
        "# First passenger\n",
        "plt.scatter(df.loc[0, \"Age\"], df.loc[0, \"Fare\"], s=120, marker='o', label=\"Passenger 1\")\n",
        "\n",
        "# Second passenger\n",
        "plt.scatter(df.loc[1, \"Age\"], df.loc[1, \"Fare\"], s=120, marker='x', label=\"Passenger 2\")\n",
        "\n",
        "plt.title(\"Age vs Fare\")\n",
        "plt.xlabel(\"Age\")\n",
        "plt.ylabel(\"Fare\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()"
