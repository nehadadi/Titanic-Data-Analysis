      "source": [
        "import pandas as pd\n",
        "\n",
        "# Read dataset\n",
        "df = pd.read_csv(\"Titanic-Dataset (1).csv\")\n",
        "\n",
        "numeric = []\n",
        "nominal = []\n",
        "binary = []\n",
        "\n",
        "for col in df.columns:\n",
        "    if df[col].nunique() == 2:\n",
        "        binary.append(col)\n",
        "    elif df[col].dtype == 'object':\n",
        "        nominal.append(col)\n",
        "    else:\n",
        "        numeric.append(col)\n",
        "\n",
        "print(\"Binary Attributes:\")\n",
        "print(binary)\n",
        "\n",
        "print(\"\\nNominal Attributes:\")\n",
        "print(nominal)\n",
        "\n",
        "print(\"\\nNumeric Attributes:\")\n",
        "print(numeric)"
      ],
